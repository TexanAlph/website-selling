# Supabase (publishable + service role for coach API only on server)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Twilio Voice SDK
TWILIO_ACCOUNT_SID=
TWILIO_API_KEY=
TWILIO_API_SECRET=
TWILIO_TWIML_APP_SID=
TWILIO_CALLER_ID=+1XXXXXXXXXX
TWILIO_CLIENT_IDENTITY=dialer-rep-1

# AI Coach — free tier defaults (see docs/FREE_STACK.md)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# STT: webspeech ($0 Safari) | auto (Deepgram if key set) | deepgram
COACH_STT_PROVIDER=webspeech
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-2
