# Supabase — browser + server routes
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Server-only: post-call playbook writes + nightly cron (Vercel Production env)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Nightly batch + Mac Mini analysis/nightly_analyze.py (Vercel → Settings → Cron)
CRON_SECRET=generate-a-long-random-string

# App login (david + x) — not Supabase Auth
DIALER_PASSWORD=Money!
DIALER_AUTH_SECRET=generate-a-long-random-string

# true = mock lead + simulated calls (local UI testing). false = real Twilio + Supabase queue
NEXT_PUBLIC_DIALER_TEST_MODE=false

# Twilio Voice SDK
TWILIO_ACCOUNT_SID=
TWILIO_API_KEY=
TWILIO_API_SECRET=
TWILIO_TWIML_APP_SID=
TWILIO_CALLER_ID=+1XXXXXXXXXX
TWILIO_CLIENT_IDENTITY=dialer-rep-1

# AI Coach — free tier defaults (see docs/FREE_STACK.md)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# STT: webspeech ($0 Safari) | auto (Deepgram if key set) | deepgram
COACH_STT_PROVIDER=webspeech
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-2
