# Mac Mini storage API (expose via Cloudflare Tunnel — see docs/LOCAL_STORAGE.md)
STORAGE_API_URL=https://your-tunnel-host.example
STORAGE_API_SECRET=generate-a-long-random-string

# Optional: test UI without Mac Mini (mock lead only)
# NEXT_PUBLIC_DIALER_TEST_MODE=true

# App login (david + roslyn) — not cloud auth
DIALER_PASSWORD=Money!
DIALER_AUTH_SECRET=generate-a-long-random-string

# Twilio Voice SDK (production calling)
TWILIO_ACCOUNT_SID=
TWILIO_API_KEY=
TWILIO_API_SECRET=
TWILIO_TWIML_APP_SID=
TWILIO_CALLER_ID=+1XXXXXXXXXX
# Optional — protects /api/twilio/recording (defaults to STORAGE_API_SECRET)
# TWILIO_WEBHOOK_SECRET=

# Phase 2 — Twilio Media Streams WSS (Mac Mini + Cloudflare Tunnel)
# MEDIA_STREAM_WSS_URL=wss://your-host.example/stream

# --- AI coach (LLM runs on Vercel only — do not put these on Mac Mini) ---

# Live coach during calls — OpenRouter + DeepSeek
OPENROUTER_API_KEY=
OPENROUTER_LIVE_MODEL=deepseek/deepseek-chat-v3-0324
# OPENROUTER_HTTP_REFERER=https://your-dialer.vercel.app

# Post-call + nightly analysis — Gemini AI Studio (free tier for Flash-Lite)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# Optional: use Gemini for live coach too (may hit free-tier rate limits)
# LIVE_LLM_PROVIDER=gemini

COACH_STT_PROVIDER=webspeech
DEEPGRAM_API_KEY=

# Optional — Mac Mini nightly_analyze.py only (Vercel cron uses x-vercel-cron header)
# CRON_SECRET=
