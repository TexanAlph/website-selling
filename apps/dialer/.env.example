# Supabase — required for real leads + coach (copy from Dashboard → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Optional: only if you want test UI without Supabase. Otherwise omit this line entirely.
# NEXT_PUBLIC_DIALER_TEST_MODE=true

# App login (david + x) — not Supabase Auth
DIALER_PASSWORD=Money!
DIALER_AUTH_SECRET=generate-a-long-random-string

# Twilio Voice SDK (production calling)
TWILIO_ACCOUNT_SID=
TWILIO_API_KEY=
TWILIO_API_SECRET=
TWILIO_TWIML_APP_SID=
TWILIO_CALLER_ID=+1XXXXXXXXXX
# Identity is auto david/x from login — do not set TWILIO_CLIENT_IDENTITY in prod

# Phase 2 — Twilio Media Streams WSS (Mac Mini + ngrok/Tailscale)
# MEDIA_STREAM_WSS_URL=wss://your-host.example/stream

# AI Coach
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Optional SOP overrides (see docs/SALES_SOP_CUSTOMIZE.md)
# COACH_COMPANY_NAME=
# COACH_OFFER_PRICE=599
# COACH_OFFER_SUMMARY=
# COACH_DELIVERY_DAYS=7-10 business days
# COACH_PAYMENT_PROCESS=
# COACH_SEND_INFO_URL=
# COACH_TARGET_GEO=San Antonio area local service businesses
COACH_STT_PROVIDER=webspeech
DEEPGRAM_API_KEY=

# Optional — Mac Mini analysis/nightly_analyze.py only (Vercel cron uses x-vercel-cron header)
# CRON_SECRET=

# Mac Mini scraper only (never put service role in Vercel for the dialer)
# SUPABASE_SERVICE_ROLE_KEY=
