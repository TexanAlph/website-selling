# Mac Mini only — do not use production keys on MacBook Air (see docs/MACHINES.md)

GOOGLE_MAPS_API_KEY=your_google_places_api_key

# SQLite database (default ~/.web-dialer/dialer.db)
# STORAGE_DB_PATH=/Users/you/.web-dialer/dialer.db

# Storage REST API (same secret as Vercel STORAGE_API_SECRET)
STORAGE_API_SECRET=generate-a-long-random-string
STORAGE_API_PORT=8787

# Optional override (default 40 in code; max 100 New leads per rep david/x)
SEARCHES_PER_RUN=40
SEARCH_WORKERS=6
DETAILS_WORKERS=6
SEARCH_CACHE_TTL_DAYS=14

# Phase 2 — prospect/rep legs (Mac Mini)
# DEEPGRAM_API_KEY=
# MEDIA_STREAM_PORT=8765
SCRAPER_CACHE_DIR=~/.web-dialer
