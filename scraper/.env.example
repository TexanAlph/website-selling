# Mac Mini only — do not use production keys on MacBook Air (see docs/MACHINES.md)
GOOGLE_MAPS_API_KEY=your_google_places_api_key
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Optional tuning
SEARCHES_PER_RUN=80
SEARCH_WORKERS=6
DETAILS_WORKERS=6
SEARCH_CACHE_TTL_DAYS=7
SCRAPER_CACHE_DIR=~/.web-dialer
